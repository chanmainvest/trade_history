# Copy to .env and fill in paths for your environment

# Database directory (contains trade_history.db, market_data.duckdb, docling_json/)
DB_PATH=data

# Statement source directory
STATEMENTS_DIR=/path/to/your/statements

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Set to 1 to enable debug logging
DEBUG=0

# LLM / LangExtract settings
LLM_BASE_URL=http://localhost:8000/VertexGen
LLM_API_KEY=your-api-key-here
LLM_MODEL_ID=gemini-3-flash
